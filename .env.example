# Backend API
NODE_ENV=development
PORT=8080
APP_BASE_URL=http://localhost:5173

# PostgreSQL (CloudSQL in cloud; local Postgres in dev)
DATABASE_URL=postgresql://dml:dml@localhost:5433/dml?schema=public

# Redis (Memorystore in cloud; local Redis in dev)
REDIS_URL=redis://localhost:6379

# Google OIDC client (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# Session cookie signing key (32+ random bytes, base64/hex)
SESSION_SIGNING_KEY=change-me-to-a-long-random-secret

# Discover (feature 003) content providers — optional; a missing key just makes
# that category serve cached/empty. Apple/iTunes (audiobooks) needs no key.
NYT_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Google Books (books Discover, alongside NYT). Optional — keyless works at low quota.
GOOGLE_BOOKS_API_KEY=
DISCOVER_TTL_SECONDS=10800

# Frontend (Vite) — proxies /api to the backend in dev
VITE_API_BASE_URL=/api
