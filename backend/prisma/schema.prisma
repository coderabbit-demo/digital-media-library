// Prisma schema for feature 001-auth-activity-feed.
//
// NOTE: The first migration must be generated with `prisma migrate dev`
// (e.g. `pnpm --filter @dml/backend prisma migrate dev --name init`).
// This file only declares the schema; the migration SQL is produced by Prisma
// and lives under prisma/migrations/. We cannot run migrations here, so a
// human must run the command above once dependencies are installed and a
// database is reachable via DATABASE_URL.
//
// Mirrors specs/001-auth-activity-feed/data-model.md exactly:
//   - UUID primary keys (gen_random_uuid via PostgreSQL)
//   - google_sub UNIQUE (dedup key, FR-003)
//   - idx_activity_feed on (createdAt DESC, id DESC) for keyset pagination
//   - idx_activity_user on (userId)
//   - idx_session_user on (userId)
//   - ON DELETE CASCADE from UserProfile to Activity and Session

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MediaType {
  book
  music
  audiobook
  podcast
}

/// A shelf in a user's library (Goodreads-style). Stored generically; the UI
/// renders media-aware labels (e.g. "Want to Read" vs "Want to Listen").
enum Shelf {
  want
  current
  done
  dnf
}

model UserProfile {
  id          String   @id @default(uuid()) @db.Uuid
  googleSub   String   @unique @map("google_sub")
  email       String?
  displayName String   @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  activities      Activity[]
  sessions        Session[]
  recommendations Recommendation[]
  libraryItems    LibraryItem[]
  replies         Reply[]
  ratings         Rating[]
  likes           ActivityLike[]

  @@map("user_profile")
}

model Activity {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  mediaType MediaType @map("media_type")
  title     String
  // Optional author/artist of the item. Column is `author` per data-model.md;
  // the API surfaces it as `itemAuthor` to avoid clashing with the post author.
  author    String?
  // Optional free-text author note/comment (feature 006), plain text.
  note      String?
  // Optional snapshot of the source item (Discover/Search/Library) for rich feed
  // cards (UI refresh): cover art, provider id, synopsis, and a provider link.
  coverUrl    String? @map("cover_url")
  providerId  String? @map("provider_id")
  description String?
  providerUrl String? @map("provider_url")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user    UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies Reply[]
  likes   ActivityLike[]

  // Keyset feed pagination ordering key (FR-008/FR-011).
  @@index([createdAt(sort: Desc), id(sort: Desc)], name: "idx_activity_feed")
  // Author lookups and cascade efficiency.
  @@index([userId], name: "idx_activity_user")
  @@map("activity")
}

model Reply {
  id         String    @id @default(uuid()) @db.Uuid
  activityId String    @map("activity_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  // Null = top-level reply; otherwise the reply this one answers (nested thread).
  parentId   String?   @map("parent_id") @db.Uuid
  body       String
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  // Soft-delete tombstone: set when a reply that has children is deleted, so the
  // thread stays coherent. Childless replies are hard-deleted instead.
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)

  // Deleting an activity removes its whole conversation (FR-012).
  activity Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Reply?       @relation("ReplyChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children Reply[]      @relation("ReplyChildren")

  @@index([activityId, createdAt], name: "idx_reply_activity")
  @@index([parentId], name: "idx_reply_parent")
  @@map("reply")
}

model Rating {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  mediaType  MediaType @map("media_type")
  providerId String    @map("provider_id")
  // 1–5 stars. One rating per user per item.
  stars      Int
  // Snapshot for a possible "your ratings" view later.
  title      String
  creator    String?
  coverUrl   String?   @map("cover_url")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaType, providerId], name: "uq_rating_user_item")
  @@map("rating")
}

model ActivityLike {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  activityId String   @map("activity_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user     UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity    @relation(fields: [activityId], references: [id], onDelete: Cascade)

  // One like per user per activity.
  @@unique([userId, activityId], name: "uq_like_user_activity")
  @@index([activityId], name: "idx_like_activity")
  @@map("activity_like")
}

model Recommendation {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  mediaType  MediaType @map("media_type")
  title      String
  // Author/artist/publisher of the item; surfaced as `itemAuthor` in the API.
  creator    String?
  coverUrl   String?   @map("cover_url")
  providerId String    @map("provider_id")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One recommendation per user per item (add is idempotent — FR-006).
  @@unique([userId, mediaType, providerId], name: "uq_recommendation_user_item")
  // Recent-first community listing.
  @@index([createdAt(sort: Desc), id(sort: Desc)], name: "idx_recommendation_recent")
  @@map("recommendation")
}

model LibraryItem {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  mediaType  MediaType @map("media_type")
  title      String
  creator    String?
  coverUrl   String?   @map("cover_url")
  providerId String    @map("provider_id")
  // Snapshot synopsis + provider link so library-started activities stay rich.
  description String?
  providerUrl String?  @map("provider_url")
  // The shelf this item sits on (default: Want to Read). Exactly one per item.
  shelf      Shelf     @default(want)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One entry per user per item (add is idempotent). Private to the owner.
  @@unique([userId, mediaType, providerId], name: "uq_library_user_item")
  // Owner's recent-first list.
  @@index([userId, createdAt(sort: Desc)], name: "idx_library_user_recent")
  @@map("library_item")
}

model Session {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(6)
  lastSeenAt DateTime @map("last_seen_at") @db.Timestamptz(6)

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_session_user")
  @@map("session")
}
