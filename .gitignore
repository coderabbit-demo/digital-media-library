# ---- OS ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- Claude Code ----
# settings.json only accumulates locally-approved permissions (personal,
# environment-specific), so it's ignored along with settings.local.json.
# Commit deliberate shared config (commands/, agents/, hooks) explicitly if needed.
.claude/settings.json
.claude/settings.local.json

# ---- Editors / IDEs ----
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.sublime-workspace

# ---- Environment / secrets ----
.env
.env.*
!.env.example
*.pem
*.key
# Ignore secret DATA files (secrets.json/yaml/env) — but NOT Terraform source,
# which only declares secret containers (no plaintext secrets live in it).
secrets.json
secrets.yaml
secrets.yml
secrets.env

# ---- Logs ----
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Node / JS ----
node_modules/
dist/
build/
.cache/
coverage/
*.tsbuildinfo
.next/
.nuxt/
.svelte-kit/
.turbo/
.vite/

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Media / generated assets ----
# Uncomment to ignore large/uploaded media if it shouldn't be versioned
# media/
# uploads/
# *.mp4
# *.mov
# *.mp3
# *.wav

# ---- Terraform ----
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform.lock.hcl
crash.log

# ---- Misc ----
tmp/
temp/
*.tmp
*.bak
.tool-versions
